{
	"layer": "top",
	"height": 500,
	"position": "left",
	"width": 46,
	"spacing": 4,
	"margin-top": 4,
	"margin-bottom": 4,
	"margin-left": 4,
	"modules-left": [
		"custom/launcher",
		"niri/workspaces"
	],
	"modules-center": [
		"clock",
		"custom/music",
		"custom/gamedock"
	],
	"modules-right": [
		"battery",
		"temperature",
		"pulseaudio",
		"backlight",
		"custom/updates",
		"tray",
		"custom/powermenu"
	],
	"niri/workspaces": {
		"format": "{icon}",
		"separate-outputs": true,
		"all-outputs": true,
		"on-click": "activate",
		"format-icons": {
			"default": "蟀嫏",
			"active": "蟀嫎"
		}
	},
	"clock": {
		"format": "{:%H\n%M}",
		"format-alt": "{:%d\n%m}",
		"tooltip": true,
		"tooltip-format": "<small>{calendar}</small>",
		"calendar": {
			"mode": "month",
			"weeks-pos": "right",
			"format": {
				"months": "<span color='#d3c6aa'><b>{}</b></span>",
				"days": "<span color='#e67e80'><b>{}</b></span>",
				"weeks": "<span color='#83c092'><b>W{}</b></span>",
				"weekdays": "<span color='#dbbc7f'><b>{}</b></span>",
				"today": "<span color='#7fbbb3'><b><u>{}</u></b></span>"
			}
		},
		"action": {
			"on-click": "mode"
		}
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "蟀伖",
		"format-charging": "蟀倓",
		"format-plugged": "蟀殽",
		"format-warning": "蟀伝",
		"format-critical": "蟀伜",
		"format-icons": [
			"蟀伜",
			"蟀伝",
			"蟀伡",
			"蟀伣",
			"蟀伨",
			"蟀伩",
			"蟀個",
			"蟀倎",
			"蟀倐",
			"蟀伖"
		]
	},
	"pulseaudio": {
		"format": "{icon}",
		"format-bluetooth": "蟀偘",
		"format-muted": "蟀潫",
		"format-icons": {
			"headphone": "蟀媼",
			"headset": "蟀嫀",
			"default": [
				"蟀暱",
				"蟀杸",
				"蟀暰"
			]
		},
		"on-click": "pavucontrol",
		"on-scroll-up": "volume --inc",
		"on-scroll-down": "volume --dec"
	},
	"backlight": {
		"device": "intel_backlight",
		"format": "蟀優 ",
		"format-icons": [
			"蟀優",
			"蟀儩",
			"蟀儫",
			"蟀儬"
		],
		"on-scroll-up": "brightness --inc",
		"on-scroll-down": "brightness --dec"
	},
	"temperature": {
		"critical-threshold": 75,
		"format": "蟀攺",
		"format-critical": "蟀竵"
	},
	"custom/launcher": {
		"format": "蟊剠",
		"on-click": "fuzzel",
		"tooltip": false
	},
	"custom/powermenu": {
		"format": "蟀惀",
		"on-click": "power-menu",
		"tooltip": false
	},
	"custom/updates": {
		"format": "{}",
		"interval": 3600,
		"exec": "~/.config/waybar/scripts/updatecheck.sh",
		"return-type": "json",
		"exec-if": "exit 0",
		"signal": 8
	},
	"tray": {
		"icon-size": 14,
		"spacing": 4
	},
	"custom/music": {
		"format": "{}",
		"return-type": "json",
		"exec": "~/.config/waybar/scripts/music.sh",
		"on-click": "playerctl play-pause",
		"on-click-right": "playerctl next",
		"on-scroll-up": "playerctl previous",
		"on-scroll-down": "playerctl next",
		"escape": true
	},
	"custom/gamedock": {
		"exec": "cat /tmp/gamedock-status 2>/dev/null || echo '{\"text\": \"蟀姉\", \"class\": \"inactive\"}'",
		"return-type": "json",
		"interval": "once",
		"signal": 9
	}
}
